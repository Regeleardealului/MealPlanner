@using MealPlannerApp.Client.Pages
@using MealPlannerApp.Client.Layout
@using Microsoft.AspNetCore.Components.Authorization

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    @* ITT A JAVÍTÁS: Beágyazás helyett átirányítjuk a felhasználót a tiszta /login URL-re *@
                    <RedirectToLogin />
                </NotAuthorized>
                <Authorizing>
                    <MudContainer Class="d-flex align-center justify-center" Style="height: 100vh;">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    </MudContainer>
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Az oldal nem található</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <MudContainer Class="mt-16">
                    <MudAlert Severity="Severity.Error">Sajnos ez az oldal nem található.</MudAlert>
                </MudContainer>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>