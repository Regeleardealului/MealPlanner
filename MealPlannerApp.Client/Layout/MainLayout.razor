@inherits LayoutComponentBase
@using Blazored.LocalStorage
@inject ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<MudThemeProvider Theme="_myCustomTheme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />

        <div class="d-flex align-center ml-3">
            <MudText Typo="Typo.h5" Style="font-weight: 700; margin-bottom: 0;">MealPlanner</MudText>

            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Class="mx-2" Style="opacity: 0.6;" />

            <MudText Style="font-family: 'Georgia', serif; font-style: italic; font-size: 1.1rem; opacity: 0.9; margin-bottom: 0; padding-top: 3px;">
                Tervezz, főzz, élj tudatosan
            </MudText>

            <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small" Class="mx-2" Style="opacity: 0.6;" />
        </div>

        <MudSpacer />

        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body1" Class="mr-4 d-none d-sm-inline">
                    Bejelentkezve: <b>@context.User.Identity?.Name</b>
                </MudText>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Inherit"
                           OnClick="Logout"
                           Size="Size.Small"
                           Class="ml-2">
                    Kijelentkezés
                </MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Outlined" Color="Color.Inherit" href="/login">Bejelentkezés</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudDrawerHeader></MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task Logout()
    {
        await LocalStorage.RemoveItemAsync("authToken");

        ((ApiAuthenticationStateProvider)AuthStateProvider).MarkUserAsLoggedOut();

        Navigation.NavigateTo("/login");
    }

    private MudTheme _myCustomTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#00897b",
            AppbarBackground = "#00897b",
        },
        Typography = new Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily = new[] { "Quicksand", "sans-serif" }
            }
        }
    };
}
