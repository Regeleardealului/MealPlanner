@page "/mealplanner"
@attribute [Authorize]
@using MealPlannerApp.Shared.Models
@using System.Globalization
@inject HttpClient Http

<PageTitle>MealPlanner</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Mit együnk a héten? 🤷‍♂️</MudText>
<MudText Class="mb-4">Húzd a recepteket a bal oldali listából a heti táblázat megfelelő cellájába!</MudText>

<div class="d-flex justify-end mb-4">
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               OnClick="@(() => Navigation.NavigateTo("/shoppinglist"))"
               StartIcon="@Icons.Material.Filled.ShoppingCartCheckout">
        Bevásárlólista Készítése
    </MudButton>
</div>

<MudGrid Spacing="3">
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Style="height: 100%;">
            <MudText Typo="Typo.h6" GutterBottom="true">Választható Receptek</MudText>
            <div style="max-height: 600px; overflow-y: auto;">
                @if (allRecipes == null)
                {
                    <MudProgressCircular Indeterminate="true" />
                }
                else
                {
                    @foreach (var recipe in allRecipes)
                    {
                        <div @key="recipe.Id" draggable="true" @ondragstart="@(() => HandleDragStart(recipe))">
                            <MudChip T="string" Color="Color.Primary" Class="ma-1" Style="cursor: grab;">@recipe.Title</MudChip>
                        </div>
                    }
                }
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="8">
        <MudTable Items="@(Enum.GetValues<MealType>())" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh></MudTh>
                @foreach (DayOfWeek day in Enum.GetValues(typeof(DayOfWeek)).Cast<DayOfWeek>().OrderBy(d => ((int)d + 6) % 7))
                {
                    @* JAVÍTÁS ITT: A teljes kifejezést @(...) blokkba tettük *@
                    <MudTh>@(new CultureInfo("hu-HU").DateTimeFormat.GetDayName(day))</MudTh>
                }
            </HeaderContent>
            <RowTemplate>
                <MudTd><b>@context</b></MudTd>
                @foreach (DayOfWeek day in Enum.GetValues(typeof(DayOfWeek)).Cast<DayOfWeek>().OrderBy(d => ((int)d + 6) % 7))
                {
                    var plannedMeal = GetPlannedMeal(day, context);
                    var dropzoneId = $"{day}-{context}";
                    <MudTd>
                        <div class="dropzone @(dropzoneId == dragOverDropzone ? "dropzone-dragover" : "")"
                             @ondrop="@(() => HandleDrop(day, context))"
                             @ondragover="HandleDragOver" @ondragover:preventDefault="true"
                             @ondragenter="@(() => dragOverDropzone = dropzoneId)"
                             @ondragleave="@(() => dragOverDropzone = null)">
                            @if (plannedMeal != null)
                            {
                                <MudChip T="string" Color="Color.Success" OnClose="@(() => RemoveMeal(plannedMeal.Id))">@plannedMeal.Recipe?.Title</MudChip>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Style="opacity: 0.5;">+</MudText>
                            }
                        </div>
                    </MudTd>
                }
            </RowTemplate>
        </MudTable>
    </MudItem>
</MudGrid>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    private List<Recipe>? allRecipes;
    private List<MealPlanEntry> mealPlan = new List<MealPlanEntry>();
    private Recipe? draggedRecipe;
    private string? dragOverDropzone;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        allRecipes = (await Http.GetFromJsonAsync<List<Recipe>>("api/recipes")) ?? new List<Recipe>();
        mealPlan = (await Http.GetFromJsonAsync<List<MealPlanEntry>>("api/mealplans")) ?? new List<MealPlanEntry>();
    }

    private void HandleDragStart(Recipe recipe)
    {
        draggedRecipe = recipe;
    }

    private void HandleDragOver() { }

    private async Task HandleDrop(DayOfWeek day, MealType type)
    {
        dragOverDropzone = null;
        if (draggedRecipe == null) return;

        var newEntry = new MealPlanEntry
        {
            Day = day,
            Type = type,
            RecipeId = draggedRecipe.Id
        };

        var response = await Http.PostAsJsonAsync("api/mealplans", newEntry);
        if (response.IsSuccessStatusCode)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private MealPlanEntry? GetPlannedMeal(DayOfWeek day, MealType type)
    {
        return mealPlan.FirstOrDefault(e => e.Day == day && e.Type == type);
    }

    private async Task RemoveMeal(int entryId)
    {
        var response = await Http.DeleteAsync($"api/mealplans/{entryId}");
        if (response.IsSuccessStatusCode)
        {
            await LoadData();
            StateHasChanged();
        }
    }
}