@page "/recommendations"
@attribute [Authorize]
@using MealPlannerApp.Shared.Models
@inject HttpClient Http

<PageTitle>MealPlanner</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Intelligens Receptajánló</MudText>
<MudText Class="mb-4">Add meg a preferenciáidat, és mi segítünk választani!</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6">
            <MudSelect T="string" @bind-value="selectedTag" Label="Étel típusa (címke)">
                <MudSelectItem T="string" Value="@("olasz")">Olasz</MudSelectItem>
                <MudSelectItem T="string" Value="@("gyors")">Gyors</MudSelectItem>
                <MudSelectItem T="string" Value="@("csirke")">Csirke</MudSelectItem>
                <MudSelectItem T="string" Value="@("magyaros")">Magyaros</MudSelectItem>
                <MudSelectItem T="string" Value="@("vegetáriánus")">Vegetáriánus</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSlider @bind-value="maxPrepTime" Min="10" Max="120" Step="5" Label="Max. elkészítési idő (perc)">@maxPrepTime perc</MudSlider>
        </MudItem>
        <MudItem xs="12" Class="d-flex justify-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GetRecommendations">Ajánlatok keresése</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (recommendedRecipes != null)
{
    <MudText Typo="Typo.h5" Class="mb-2">Ajánlott Receptek</MudText>
    <MudGrid Spacing="3">
        @foreach (var recipe in recommendedRecipes)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard>
                    <MudCardMedia Image="@recipe.ImageUrl" Height="200" />
                    <MudCardContent>
                        <MudText Typo="Typo.h5">@recipe.Title</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}


@code {
    private string selectedTag = "olasz";
    private double maxPrepTime = 60;
    private bool isLoading = false;
    private Recipe[]? recommendedRecipes;

    private async Task GetRecommendations()
    {
        isLoading = true;
        recommendedRecipes = null;

        // Összeállítjuk az URL-t a query paraméterekkel
        var requestUri = $"api/recommendations?maxPrepTime={maxPrepTime}&tag={selectedTag}";

        try
        {
            recommendedRecipes = await Http.GetFromJsonAsync<Recipe[]>(requestUri);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Hiba az ajánlatok lekérésekor: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}