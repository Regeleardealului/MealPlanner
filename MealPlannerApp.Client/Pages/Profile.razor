@page "/profil"
@attribute [Authorize]
@using MealPlannerApp.Shared.Models
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>MealPlanner</PageTitle>

<MudText Typo="Typo.h3" Class="mb-2" Style="color: #424242; font-weight: 600;">Profil beállítások ⚙️</MudText>
<MudText Typo="Typo.body1" Class="mb-6">Testreszabhatod a diétádat, hogy az Okos Konyhatárs mindig megfelelő recepteket ajánljon!</MudText>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6" Color="Color.Primary">

    @* --- 1. FÜL: DIÉTA ÉS PREFERENCIÁK --- *@
    <MudTabPanel Text="Diéta és Preferenciák" Icon="@Icons.Material.Filled.RestaurantMenu">
        @if (isLoading)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudCard Elevation="0" Class="pa-4" Style="background-color: #f4f6f8; border-radius: 8px;">
                        <MudText Typo="Typo.h6" Class="mb-4">Alapvető diéták</MudText>

                        <MudSwitch @bind-Value="preferences.IsVegetarian" Color="Color.Success" Label="Vegetáriánus vagyok" Class="mb-2" />
                        <MudSwitch @bind-Value="preferences.IsVegan" Color="Color.Success" Label="Vegán vagyok" Class="mb-2" />
                        <MudSwitch @bind-Value="preferences.IsGlutenFree" Color="Color.Warning" Label="Gluténmentesen étkezem" Class="mb-2" />
                        <MudSwitch @bind-Value="preferences.IsLactoseFree" Color="Color.Warning" Label="Laktózmentesen étkezem" Class="mb-2" />
                    </MudCard>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudCard Elevation="0" Class="pa-4" Style="background-color: #f4f6f8; border-radius: 8px;">
                        <MudText Typo="Typo.h6" Class="mb-4">Allergiák és miket nem szeretsz?</MudText>
                        <MudText Typo="Typo.body2" Class="mb-4">Sorold fel vesszővel elválasztva azokat az alapanyagokat, amiket el szeretnél kerülni (pl. gomba, földimogyoró, mazsola).</MudText>

                        <MudTextField @bind-Value="preferences.AllergiesOrDislikes"
                                      Label="Nem szeretem / Allergiás vagyok erre:"
                                      Variant="Variant.Outlined"
                                      Lines="4" />
                    </MudCard>
                </MudItem>
            </MudGrid>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="mt-6" OnClick="SavePreferences">
                Beállítások Mentése
            </MudButton>
        }
    </MudTabPanel>

    @* --- 2. FÜL: BIZTONSÁG ÉS JELSZÓ --- *@
    <MudTabPanel Text="Jelszó módosítás" Icon="@Icons.Material.Filled.Security">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" Class="mb-4">Jelszó megváltoztatása</MudText>

                <MudTextField @bind-Value="passwordDto.CurrentPassword" Label="Jelenlegi jelszó" Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-4" />
                <MudTextField @bind-Value="passwordDto.NewPassword" Label="Új jelszó" Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-4" />
                <MudTextField @bind-Value="passwordDto.ConfirmNewPassword" Label="Új jelszó megerősítése" Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-6" />

                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="ChangePassword">
                    Jelszó Cseréje
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

</MudTabs>

@code {
    private UserPreferencesDto preferences = new();
    private ChangePasswordDto passwordDto = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Amikor megnyílik az oldal, betöltjük a mentett beállításokat
            preferences = await Http.GetFromJsonAsync<UserPreferencesDto>("api/profile/preferences") ?? new UserPreferencesDto();
        }
        catch (Exception)
        {
            Snackbar.Add("Hiba a beállítások betöltésekor.", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SavePreferences()
    {
        var response = await Http.PutAsJsonAsync("api/profile/preferences", preferences);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("A diéta beállításaid sikeresen elmentve!", Severity.Success);
        }
        else
        {
            Snackbar.Add("Hiba a mentés során.", Severity.Error);
        }
    }

    private async Task ChangePassword()
    {
        if (passwordDto.NewPassword != passwordDto.ConfirmNewPassword)
        {
            Snackbar.Add("A két új jelszó nem egyezik!", Severity.Warning);
            return;
        }

        var response = await Http.PostAsJsonAsync("api/profile/change-password", passwordDto);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Jelszó sikeresen megváltoztatva!", Severity.Success);
            passwordDto = new ChangePasswordDto(); // Mezők kiürítése
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            Snackbar.Add($"Hiba: {error}", Severity.Error);
        }
    }
}